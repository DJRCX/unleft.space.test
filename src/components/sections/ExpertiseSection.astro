---
import ExpertiseContent from '@/components/sections/ExpertiseContent';
---

<section class="relative mx-auto w-full px-6 py-24 overflow-hidden">
  <div class="relative z-10 mx-auto max-w-7xl">
    <div class="mb-14 text-center">
      <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-[#9CA3AF] font-gupter">Why Unleft</p>
      <h2 class="text-3xl font-bold text-[#E5E7EB] md:text-4xl">Our Expertise</h2>
      <p class="mx-auto mt-4 max-w-2xl text-[#9CA3AF]">
        What sets us apart — the principles that drive every project we build.
      </p>
    </div>

    <ExpertiseContent client:visible />
  </div>
</section>
