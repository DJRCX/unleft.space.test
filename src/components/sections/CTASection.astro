---
import CTAButtons from '@/components/sections/CTAButtons';
---

<section class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-card to-background border border-border p-12 md:p-20 text-center">
      <!-- Glow backgrounds -->
      <div class="absolute -top-24 -left-24 h-64 w-64 rounded-full bg-accent-primary/20 blur-[100px]"></div>
      <div class="absolute -bottom-24 -right-24 h-64 w-64 rounded-full bg-accent-secondary/20 blur-[100px]"></div>
      
      <div class="relative z-10">
        <h2 class="mb-6 text-3xl font-bold text-text-primary md:text-5xl">Ready to engineer your future?</h2>
        <p class="mx-auto mb-10 max-w-xl text-lg text-muted-foreground">
          Let's discuss how we can help you build something extraordinary. Our team is ready to scale your vision.
        </p>
        <CTAButtons client:visible />
      </div>
    </div>
  </div>
</section>
