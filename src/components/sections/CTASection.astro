---
import { Button } from '@/components/ui/button';
import { ArrowRight } from 'lucide-react';
---

<section class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-[#1A1A2E] to-[#0A0A0F] border border-[#2D2D44] p-12 md:p-20 text-center">
      <!-- Glow backgrounds -->
      <div class="absolute -top-24 -left-24 h-64 w-64 rounded-full bg-accent-primary/20 blur-[100px]"></div>
      <div class="absolute -bottom-24 -right-24 h-64 w-64 rounded-full bg-accent-secondary/20 blur-[100px]"></div>
      
      <div class="relative z-10">
        <h2 class="mb-6 text-3xl font-bold text-text-primary md:text-5xl">Ready to engineer your future?</h2>
        <p class="mx-auto mb-10 max-w-xl text-lg text-text-secondary">
          Let's discuss how we can help you build something extraordinary. Our team is ready to scale your vision.
        </p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button size="lg" className="h-14 border-none bg-gradient-to-r from-[#7B2CBF] to-[#9D4EDD] px-10 text-lg font-bold text-white shadow-[0_0_20px_rgba(124,58,237,0.4)] transition-all hover:scale-105">
            Start a Project
          </Button>
          <a href="/contact" class="group flex items-center gap-2 text-text-primary transition-colors hover:text-accent-glow">
            Contact Us
            <ArrowRight class="h-5 w-5 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
