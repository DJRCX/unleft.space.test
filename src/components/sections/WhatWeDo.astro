---
import ServicesGrid from '@/components/sections/ServicesGrid';
---

<section class="mx-auto max-w-7xl px-6 py-24">
  <div class="mb-14 text-center">
    <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-[#9CA3AF]">What We Do</p>
    <h2 class="text-3xl font-bold text-[#E5E7EB] md:text-4xl">Our Core Services</h2>
    <p class="mx-auto mt-4 max-w-2xl text-[#9CA3AF]">
      End-to-end technical execution with a focus on speed, performance, and scalability.
    </p>
  </div>

  <ServicesGrid client:visible />
</section>
