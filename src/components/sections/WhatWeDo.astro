---
import ServicesGrid from '@/components/sections/ServicesGrid';
---

<section class="relative mx-auto w-full px-6 py-24 overflow-hidden">
  <div class="relative z-10 mx-auto max-w-7xl">
    <div class="mb-14 text-center">
      <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground font-gupter">What We Do</p>
      <h2 class="text-3xl font-bold text-foreground md:text-4xl">Our Core Services</h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted-foreground">
        End-to-end technical execution with a focus on speed, performance, and scalability.
      </p>
    </div>

    <ServicesGrid client:visible />
  </div>
</section>
