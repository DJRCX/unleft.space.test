---
import PageLayout from '@/layouts/PageLayout.astro';
import Terminal from '@/components/ui/Terminal';
import CTASection from '@/components/sections/CTASection.astro';
import { Badge } from '@/components/ui/badge';

const categories = [
  {
    name: 'Frontend',
    color: 'text-blue-400',
    borderColor: 'border-blue-500/20',
    bgColor: 'bg-blue-500/5',
    tools: [
      { name: 'React', level: 95 },
      { name: 'Next.js', level: 90 },
      { name: 'Astro', level: 92 },
      { name: 'Tailwind CSS', level: 98 },
      { name: 'Framer Motion', level: 85 },
    ],
  },
  {
    name: 'Backend',
    color: 'text-emerald-400',
    borderColor: 'border-emerald-500/20',
    bgColor: 'bg-emerald-500/5',
    tools: [
      { name: 'Node.js', level: 90 },
      { name: 'Python', level: 85 },
      { name: 'Django', level: 80 },
      { name: 'PostgreSQL', level: 88 },
      { name: 'MongoDB', level: 82 },
    ],
  },
  {
    name: 'Game & 3D',
    color: 'text-purple-400',
    borderColor: 'border-purple-500/20',
    bgColor: 'bg-purple-500/5',
    tools: [
      { name: 'Unity', level: 88 },
      { name: 'C#', level: 85 },
      { name: 'Three.js', level: 80 },
      { name: 'WebGL', level: 75 },
      { name: 'Blender', level: 70 },
    ],
  },
  {
    name: 'DevOps & AI',
    color: 'text-orange-400',
    borderColor: 'border-orange-500/20',
    bgColor: 'bg-orange-500/5',
    tools: [
      { name: 'Docker', level: 85 },
      { name: 'Vercel', level: 95 },
      { name: 'AWS', level: 75 },
      { name: 'TensorFlow', level: 70 },
      { name: 'OpenAI API', level: 80 },
    ],
  },
];
---

<PageLayout title="Tech Stack" description="The technologies powering UNLEFT's digital solutions.">
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <Badge className="mb-6 bg-accent-primary/10 text-accent-glow border-none">Our Stack</Badge>
        <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-8 tracking-tight">
          The <span class="text-accent-primary">Engine</span> Behind It.
        </h1>
        <p class="text-xl text-text-secondary leading-relaxed mb-10">
          We use a battle-tested, high-performance stack. Static-first architecture with interactive islands for maximum speed.
        </p>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="mt-1 h-6 w-6 rounded-md bg-accent-primary/20 flex items-center justify-center flex-shrink-0">
              <div class="h-2 w-2 rounded-full bg-accent-primary animate-pulse"></div>
            </div>
            <div>
              <h3 class="font-bold text-text-primary">Islands Architecture</h3>
              <p class="text-sm text-text-secondary">Zero JavaScript by default. React islands only where interactivity is needed.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="mt-1 h-6 w-6 rounded-md bg-accent-secondary/20 flex items-center justify-center flex-shrink-0">
              <div class="h-2 w-2 rounded-full bg-accent-secondary animate-pulse"></div>
            </div>
            <div>
              <h3 class="font-bold text-text-primary">GPU Accelerated UI</h3>
              <p class="text-sm text-text-secondary">Three.js scenes, Framer Motion animations — all performance-budgeted.</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-accent-primary to-accent-secondary rounded-2xl blur opacity-20"></div>
        <div class="relative bg-[#0A0A0F] rounded-2xl p-4">
          <Terminal client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- Tech categories with skill bars -->
  <section class="bg-[#1A1A2E]/30 py-24">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">Technology Proficiency</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {categories.map((cat) => (
          <div class={`rounded-xl border ${cat.borderColor} ${cat.bgColor} p-6`}>
            <h3 class={`font-bold text-lg mb-6 ${cat.color}`}>{cat.name}</h3>
            <div class="space-y-4">
              {cat.tools.map((tool) => (
                <div>
                  <div class="flex justify-between mb-1">
                    <span class="text-sm text-text-primary font-mono">{tool.name}</span>
                    <span class="text-xs text-text-secondary">{tool.level}%</span>
                  </div>
                  <div class="h-2 w-full bg-[#0A0A0F] rounded-full overflow-hidden">
                    <div
                      class={`h-full rounded-full bg-gradient-to-r from-accent-primary to-accent-glow`}
                      style={`width: ${tool.level}%`}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</PageLayout>
