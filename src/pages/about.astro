---
import PageLayout from '@/layouts/PageLayout.astro';
import CTASection from '@/components/sections/CTASection.astro';
import { Badge } from '@/components/ui/badge';
import { Rocket, Target, Globe, Heart } from 'lucide-react';

const values = [
  { icon: Rocket, title: 'Innovation', desc: 'We push boundaries — from AI-powered systems to WebGL-rendered game worlds.' },
  { icon: Target, title: 'Performance', desc: 'Zero compromise on speed. Every project targets >90 Lighthouse scores.' },
  { icon: Globe, title: 'Scalability', desc: 'Architecture that grows with you, from MVP to enterprise-grade scale.' },
  { icon: Heart, title: 'Reliability', desc: 'Clean code, rigorous testing, and ongoing support you can count on.' },
];

const roadmap = [
  { year: 'Year 1', label: 'Service Provider', desc: 'Business websites, custom software, and early game prototypes.', active: true },
  { year: 'Year 2', label: 'Game Studio + SaaS', desc: 'Unity game releases, first SaaS product, and international clients.' },
  { year: 'Year 3', label: 'Global Brand', desc: 'Published games, multiple SaaS products, and a global engineering presence.' },
];
---

<PageLayout title="About Us" description="Learn about Unleft's mission, values, and vision for the future.">
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <Badge className="mb-6 bg-accent-primary/10 text-accent-glow border-none">About Unleft</Badge>
        <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-8 tracking-tight">
          Beyond Software.
        </h1>
        <p class="text-xl text-text-secondary leading-relaxed mb-6">
          Unleft is a futuristic, performance-driven software solutions company. We build business websites, scalable software systems, and cross-platform games.
        </p>
        <p class="text-lg text-text-secondary leading-relaxed">
          Founded in Dhaka, Bangladesh, with a relentless global ambition — we combine the creativity of a game studio with the precision of enterprise engineering.
        </p>
      </div>
      
      <div class="relative">
        <div class="absolute -inset-4 bg-gradient-to-r from-accent-primary/10 to-accent-secondary/10 rounded-3xl blur-2xl"></div>
        <div class="relative rounded-2xl border border-[#2D2D44] bg-[#0A0A0F] p-8 md:p-10">
          <blockquote class="text-2xl font-heading font-bold text-text-primary leading-tight italic">
            "Choose Unleft for multidisciplinary excellence — where gaming meets enterprise, and creativity meets performance."
          </blockquote>
          <p class="mt-4 text-sm text-accent-glow font-mono">— Our Promise</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="bg-[#1A1A2E]/30 py-24">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">Core Values</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((v) => (
          <div class="rounded-xl border border-[#2D2D44] bg-[#0A0A0F]/50 p-6 hover:border-accent-glow/30 transition-all group">
            <div class="mb-4 h-12 w-12 rounded-lg bg-accent-primary/10 flex items-center justify-center group-hover:bg-accent-primary/20 transition-colors">
              <v.icon class="h-6 w-6 text-accent-glow" />
            </div>
            <h3 class="font-bold text-text-primary mb-2">{v.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">Our 3-Year Arc</h2>
    <div class="relative">
      <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-accent-primary via-accent-glow/30 to-transparent"></div>
      <div class="space-y-12">
        {roadmap.map((phase, i) => (
          <div class={`relative flex flex-col md:flex-row items-start gap-8 ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
            <div class="flex-1"></div>
            <div class="relative z-10 flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-full border-2 border-accent-primary bg-[#0A0A0F]">
              <span class={`text-xs font-mono font-bold ${phase.active ? 'text-accent-glow' : 'text-text-secondary'}`}>{phase.year}</span>
            </div>
            <div class="flex-1">
              <div class={`rounded-xl border p-6 ${phase.active ? 'border-accent-primary bg-accent-primary/5' : 'border-[#2D2D44] bg-[#1A1A2E]/30'}`}>
                <h3 class="font-bold text-text-primary mb-2">{phase.label}</h3>
                <p class="text-sm text-text-secondary">{phase.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</PageLayout>
