---
import PageLayout from '@/layouts/PageLayout.astro';
import ContactForm from '@/components/sections/ContactForm';
import { Mail, MapPin, Github, Linkedin } from 'lucide-react';
---

<PageLayout title="Contact" description="Get in touch with UNLEFT. Let's build something extraordinary.">
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="grid lg:grid-cols-2 gap-16">
      <!-- Info side -->
      <div>
        <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-8">Let's build.</h1>
        <p class="text-xl text-text-secondary leading-relaxed mb-12 max-w-md">
          Ready to turn your vision into high-performance digital reality? Drop us a message or find us on social.
        </p>
        
        <div class="space-y-8">
          <a href="mailto:hello@unleft.space" class="flex items-center gap-4 text-text-secondary hover:text-accent-glow transition-colors group">
            <div class="h-10 w-10 rounded-full bg-[#1A1A2E] flex items-center justify-center group-hover:bg-accent-primary/20 transition-colors">
              <Mail class="h-5 w-5" />
            </div>
            <span>hello@unleft.space</span>
          </a>
          <div class="flex items-center gap-4 text-text-secondary">
            <div class="h-10 w-10 rounded-full bg-[#1A1A2E] flex items-center justify-center">
              <MapPin class="h-5 w-5" />
            </div>
            <span>Dhaka, Bangladesh</span>
          </div>
          
          <div class="flex gap-4 pt-4">
            <a href="https://github.com/unleft" target="_blank" rel="noopener noreferrer" class="h-12 w-12 rounded-xl border border-[#2D2D44] flex items-center justify-center hover:bg-[#1A1A2E] hover:border-accent-glow/30 transition-all">
              <Github class="h-6 w-6 text-text-secondary" />
            </a>
            <a href="https://linkedin.com/company/unleft" target="_blank" rel="noopener noreferrer" class="h-12 w-12 rounded-xl border border-[#2D2D44] flex items-center justify-center hover:bg-[#1A1A2E] hover:border-accent-glow/30 transition-all">
              <Linkedin class="h-6 w-6 text-text-secondary" />
            </a>
          </div>
        </div>

        <div class="mt-12 rounded-xl border border-[#2D2D44] bg-[#1A1A2E]/30 p-6">
          <p class="text-sm text-text-secondary">
            <span class="text-accent-glow font-semibold">Expected Response Time:</span><br />
            We reply within 24 hours during business days. For urgent requests, email us directly.
          </p>
        </div>
      </div>
      
      <!-- Form side -->
      <div class="rounded-3xl border border-[#2D2D44] bg-[#1A1A2E]/40 p-8 md:p-12 backdrop-blur-sm shadow-2xl">
        <ContactForm client:load />
      </div>
    </div>
  </section>
</PageLayout>
